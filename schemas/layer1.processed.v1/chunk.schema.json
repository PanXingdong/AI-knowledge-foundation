{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://panxingdong.github.io/AI-knowledge-foundation/schemas/layer1.processed.v1/chunk.schema.json",
  "title": "Layer1 Processed Chunk",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "chunk_id",
    "document_version_id",
    "section_path",
    "page_start",
    "page_end",
    "text",
    "evidence_ids",
    "embedding_id",
    "metadata"
  ],
  "properties": {
    "chunk_id": {
      "type": "string"
    },
    "document_version_id": {
      "type": "string"
    },
    "section_path": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "page_start": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ]
    },
    "page_end": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ]
    },
    "text": {
      "type": "string"
    },
    "evidence_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "embedding_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "document_id",
        "document_title",
        "source_type"
      ],
      "properties": {
        "document_id": {
          "type": "string"
        },
        "document_title": {
          "type": "string"
        },
        "source_type": {
          "type": "string"
        }
      }
    }
  }
}
