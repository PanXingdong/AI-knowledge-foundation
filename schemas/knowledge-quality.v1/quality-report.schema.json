{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-knowledge-foundation.local/schemas/knowledge-quality.v1/quality-report.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "policy_id",
    "policy_version",
    "policy_hash",
    "mode",
    "artifact_fingerprint",
    "determinism_fingerprint",
    "document_version_ids",
    "signals",
    "decisions",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "const": "knowledge-quality-report.v1"
    },
    "policy_id": {
      "type": "string",
      "minLength": 1
    },
    "policy_version": {
      "type": "string",
      "minLength": 1
    },
    "policy_hash": {
      "type": "string",
      "minLength": 64,
      "maxLength": 64
    },
    "mode": {
      "const": "observe"
    },
    "artifact_fingerprint": {
      "type": "string",
      "minLength": 1
    },
    "determinism_fingerprint": {
      "type": "string",
      "minLength": 1
    },
    "document_version_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "signals": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/signal"
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/decision"
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    }
  },
  "$defs": {
    "signal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signal_id",
        "reason_code",
        "scope",
        "object_id",
        "detector",
        "detector_version",
        "metric_name",
        "actual_value",
        "threshold",
        "confidence",
        "severity",
        "document_version_id",
        "page",
        "block_id",
        "chunk_id",
        "evidence_ids",
        "message"
      ],
      "properties": {
        "signal_id": {
          "type": "string",
          "minLength": 1
        },
        "reason_code": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "enum": [
            "document",
            "page",
            "block",
            "chunk",
            "release"
          ]
        },
        "object_id": {
          "type": "string",
          "minLength": 1
        },
        "detector": {
          "type": "string",
          "minLength": 1
        },
        "detector_version": {
          "type": "string",
          "minLength": 1
        },
        "metric_name": {
          "type": "string",
          "minLength": 1
        },
        "actual_value": {
          "type": [
            "string",
            "number",
            "boolean",
            "null"
          ]
        },
        "threshold": {
          "type": [
            "string",
            "number",
            "boolean",
            "null"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "severity": {
          "enum": [
            "info",
            "warning",
            "error",
            "fatal"
          ]
        },
        "document_version_id": {
          "type": "string",
          "minLength": 1
        },
        "page": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "block_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "chunk_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "evidence_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "message": {
          "type": "string"
        }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_id",
        "signal_ids",
        "policy_id",
        "policy_version",
        "mode",
        "recommended_action",
        "effective_action",
        "scope",
        "object_id",
        "reason_codes",
        "artifact_fingerprint"
      ],
      "properties": {
        "decision_id": {
          "type": "string",
          "minLength": 1
        },
        "signal_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "policy_id": {
          "type": "string",
          "minLength": 1
        },
        "policy_version": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "const": "observe"
        },
        "recommended_action": {
          "enum": [
            "allow",
            "warn",
            "quarantine",
            "block_document",
            "block_release"
          ]
        },
        "effective_action": {
          "enum": [
            "allow",
            "warn"
          ]
        },
        "scope": {
          "enum": [
            "document",
            "page",
            "block",
            "chunk",
            "release"
          ]
        },
        "object_id": {
          "type": "string",
          "minLength": 1
        },
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "artifact_fingerprint": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
