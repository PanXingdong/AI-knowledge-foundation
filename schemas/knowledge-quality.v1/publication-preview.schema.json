{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-knowledge-foundation.local/schemas/knowledge-quality.v1/publication-preview.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "policy_id",
    "policy_version",
    "mode",
    "all_document_version_ids",
    "all_chunk_ids",
    "would_exclude_document_version_ids",
    "would_exclude_chunk_ids",
    "decision_ids"
  ],
  "properties": {
    "schema_version": {
      "const": "knowledge-publication-preview.v1"
    },
    "policy_id": {
      "type": "string",
      "minLength": 1
    },
    "policy_version": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "const": "observe"
    },
    "all_document_version_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "all_chunk_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "would_exclude_document_version_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "would_exclude_chunk_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "decision_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  }
}
